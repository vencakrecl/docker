#!/bin/sh
# Install Composer to /usr/local/bin/composer (sha256-verified).
# Usage: jarvis-install-composer
set -eu
me="${0##*/}"

# validate input + usage
case "${1:-}" in -h|--help) echo "usage: $me"; exit 0 ;; esac
[ "$#" -eq 0 ] || { echo "usage: $me" >&2; exit 2; }

# renovate: datasource=github-releases depName=composer/composer
COMPOSER_VERSION="${COMPOSER_VERSION:-2.10.2}"
COMPOSER_SHA256="${COMPOSER_SHA256:-5ee7125f8a30a34d246cefdc0bc85b8a783b28f2aec968994118512350d28027}"

# _fetch <url> <dest> - download, bootstrapping curl + CA certs first if missing.
_fetch() {
    command -v curl >/dev/null 2>&1 || jarvis-install-runtime-deps ca-certificates curl
    curl -fsSL "$1" -o "$2"
}

tmp="$(mktemp -d)"
_fetch "https://getcomposer.org/download/${COMPOSER_VERSION}/composer.phar" "$tmp/composer.phar"
jarvis-verify-sha256 "$tmp/composer.phar" "$COMPOSER_SHA256"
install -m 0755 "$tmp/composer.phar" /usr/local/bin/composer
rm -rf "$tmp"

# report installed version (or fail loudly via set -e if it can't run)
echo "$me: installed $(composer --version --no-interaction)"
