#!/command/with-contenv sh
# shellcheck shell=sh
exec 2>&1
# nginx cannot expand env vars in its config, so render the template into /run
# (writable by www-data) and point nginx at it. Only our ${SERVER_ROOT} and
# ${FASTCGI_READ_TIMEOUT} placeholders are substituted; nginx's own $uri/$document_root
# are left intact. The fastcgi read timeout defaults to PHP's max_execution_time (so
# nginx waits as long as PHP may run), overridable via SERVER_TIMEOUT.
fcgi_timeout="${SERVER_TIMEOUT:-${PHP_MAX_EXECUTION_TIME:-30}}"
# Must be a positive integer of seconds: nginx reads 0 as "time out immediately", so a
# 0 (or non-numeric) value is a misconfiguration, not "unlimited". PHP_MAX_EXECUTION_TIME=0
# (unlimited) therefore has no backend-timeout equivalent - set SERVER_TIMEOUT explicitly.
case "$fcgi_timeout" in
    '' | *[!0-9]* | 0)
        echo "nginx: SERVER_TIMEOUT must be a positive integer of seconds (got '$fcgi_timeout'); set it explicitly." >&2
        exit 1 ;;
esac
sed -e "s#\${SERVER_ROOT}#${SERVER_ROOT}#g" \
    -e "s#\${FASTCGI_READ_TIMEOUT}#${fcgi_timeout}#g" \
    /etc/nginx/nginx.conf.template > /run/nginx.conf
exec nginx -c /run/nginx.conf -g "daemon off;"
