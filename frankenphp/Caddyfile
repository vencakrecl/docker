# FrankenPHP + Caddy config, loaded via the base CMD's `--config /etc/frankenphp/Caddyfile`.
# Owns the base image's env-driven config, trimmed of the upstream Mercure/Vulcain blocks.
{
	# Plain HTTP on :8080 (SERVER_NAME); no local cert-trust install.
	skip_install_trust

	{$CADDY_GLOBAL_OPTIONS}

	frankenphp {
		{$FRANKENPHP_CONFIG}
	}
}

{$CADDY_EXTRA_CONFIG}

{$SERVER_NAME:localhost} {
	root {$SERVER_ROOT:/app/public}
	encode zstd br gzip

	# Static liveness endpoint (default HEALTHCHECK_PATH), runs no PHP.
	respond /healthz 200

	# User escape hatch, e.g. `-e CADDY_SERVER_EXTRA_DIRECTIVES=log` for access logs.
	{$CADDY_SERVER_EXTRA_DIRECTIVES}

	php_server
}

import Caddyfile.d/*.caddyfile
