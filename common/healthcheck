#!/bin/sh
# Container HEALTHCHECK probe for the web images. HTTP GET the health endpoint and
# exit 0 only on a 2xx/3xx status. HEALTHCHECK_PATH defaults to /healthz (on
# HEALTHCHECK_PORT, default 8080): a cheap, app-independent liveness endpoint answered
# by php-fpm's ping (fpm images) or a Caddy static 200 (frankenphp) - healthy means the
# web server + PHP runtime accept connections, no app code runs. For an end-to-end
# check that PHP executes through the whole stack, set HEALTHCHECK_PATH=/ (serves the
# docroot index.php); point it at your app's own route (e.g. Laravel /up) to also
# validate the application.
set -eu

url="http://127.0.0.1:${HEALTHCHECK_PORT:-8080}${HEALTHCHECK_PATH:-/}"

if command -v curl >/dev/null 2>&1; then
    exec curl -fsS --max-time 5 -o /dev/null "$url"
fi

# Fallback: PHP is always present in these images (curl usually is too).
exec php -r '
$ctx = stream_context_create(["http" => ["timeout" => 5, "ignore_errors" => true]]);
$body = @file_get_contents($argv[1], false, $ctx);
if ($body === false) { exit(1); }
foreach ($http_response_header as $h) {
    if (preg_match("#^HTTP/\\S+ ([0-9]+)#", $h, $m)) {
        exit((int) $m[1] >= 200 && (int) $m[1] < 400 ? 0 : 1);
    }
}
exit(1);
' "$url"
